# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allow requests from your domain and auth subdomain
CORS_ORIGIN_GAME_CLIENT=https://game.korczewski.de

# =============================================================================
# EXTERNAL SERVICE URLS
# =============================================================================
# Auth server URL - should be separate subdomain or port
AUTH_APP_URL=https://auth.korczewski.de
# If using same domain with different ports in development:
# AUTH_APP_URL=https://game.korczewski.de:3001

# =============================================================================
# FIREBASE ADMIN SDK CONFIGURATION (Server-Side)
# =============================================================================
# Path to service account key (Docker container path)
GOOGLE_APPLICATION_CREDENTIALS=/usr/src/app/service-account.json

# =============================================================================
# FIREBASE CLIENT SDK CONFIGURATION (Client-Side Injection)
# =============================================================================
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=kommillitonen-quiz.firebaseapp.com
FIREBASE_PROJECT_ID=kommillitonen-quiz
FIREBASE_STORAGE_BUCKET=kommillitonen-quiz.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=215136246569
FIREBASE_APP_ID=1:215136246569:web:7431d308369d9fb4d17538
FIREBASE_MEASUREMENT_ID=

# =============================================================================
# SESSION & SECURITY CONFIGURATION
# =============================================================================
# These are used by the client-side for session handling
SESSION_COOKIE_NAME=quiz_game_session
CSRF_TOKEN_HEADER_NAME=X-CSRF-Token

# =============================================================================
# DEVELOPMENT OVERRIDES (uncomment for local development)
# =============================================================================
PORT=3000
NODE_ENV=development
#NODE_ENV=production
CORS_ORIGIN_GAME_CLIENT=http://localhost:3000
AUTH_APP_URL=http://localhost:3001